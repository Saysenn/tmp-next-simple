# ============================================================
#  EMAIL PROVIDER
# ============================================================
EMAIL_PROVIDER=resend                        # resend | smtp
MAIL_FROM_NAME=MyApp
CONTACT_EMAIL=you@example.com               # required — where form notifications go
NEXT_PUBLIC_SITE_URL=https://yourdomain.com  # used in email footers/links

# ---- Resend (default) ----
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=onboarding@resend.dev      # use your verified domain in production

# ---- SMTP (alternative) ----
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false                            # true = port 465 (SSL), false = port 587 (STARTTLS)
SMTP_USER=you@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM_EMAIL=you@gmail.com               # falls back to SMTP_USER if empty

# ============================================================
#  CAPTCHA  (only fill the provider you're using)
# ============================================================

# Cloudflare Turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=0x4AAAAAAA...
TURNSTILE_SECRET_KEY=0x4AAAAAAA...

# Google reCAPTCHA v2 / v3
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=6Lc...
RECAPTCHA_SECRET_KEY=6Lc...
